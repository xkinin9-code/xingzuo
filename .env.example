# 数据库配置
# 使用Supabase PostgreSQL连接字符串
DATABASE_URL="file:./dev.db"

# AI服务配置（可选，用于内容润色）
# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4-turbo-preview"

# 或 Anthropic Claude
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-sonnet-20240229"

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="星座运势每日占卜"
NEXT_PUBLIC_SITE_DESCRIPTION="输入生日，获取你的今日星座运势"

# 支付配置（模拟）
NEXT_PUBLIC_MOCK_PAYMENT_ENABLED="true"
NEXT_PUBLIC_MOCK_PAYMENT_SUCCESS_RATE="100" # 模拟支付成功率百分比

# Vercel Blob存储（用于分享卡片）
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# 可选：分析工具
# NEXT_PUBLIC_GA_ID="UA-..."
# NEXT_PUBLIC_UMAMI_ID="..."

# 可选：安全配置
# NEXT_PUBLIC_CSP_ENABLED="true"

# 开发配置
NODE_ENV="development"